# Configuração do banco de dados
# Copie este arquivo para .env e ajuste os valores
DB_HOST=localhost
DB_NAME=devshowcase_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Ambiente: development | production
ENVIRONMENT=development

# URL base da API (sem barra no final)
API_URL=http://localhost/devshowcase/backend/api
